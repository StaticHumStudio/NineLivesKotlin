<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules (API < 31): Exclude encrypted prefs and legacy settings
    from Google cloud backup. Auth tokens and server credentials must not
    be backed up — they could be restored to a different device.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="nine_lives_secure_prefs.xml" />
    <exclude domain="file" path="NineLivesAudio/settings.json" />
</full-backup-content>
