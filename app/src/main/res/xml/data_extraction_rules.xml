<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules (API 31+): Exclude encrypted prefs from cloud backup.
    Auth tokens and server credentials must not leave the device via backup.
    Device-to-device transfer allows non-sensitive prefs but excludes secrets.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="nine_lives_secure_prefs.xml" />
        <exclude domain="file" path="NineLivesAudio/settings.json" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="nine_lives_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
