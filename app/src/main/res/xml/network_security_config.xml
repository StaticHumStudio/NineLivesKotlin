<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Cleartext HTTP is permitted because Audiobookshelf servers are commonly
        self-hosted on local networks using raw IP addresses (e.g., http://192.168.1.50:13378).
        Android's domain-config does not support IP CIDR ranges, so we cannot restrict
        cleartext to private IPs only via XML.

        Mitigations:
        • normalizeServerUrl() defaults to HTTPS when no scheme is provided — users must
          explicitly type "http://" to use cleartext (opt-in).
        • The auth token is sent via Authorization header, never in URL query params.
        • Self-signed cert acceptance is gated behind an explicit user setting
          (allowSelfSignedCertificates, defaults to false).
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
